# ─────────────────────────────────────────────────────────────
#  Настройки бота-магазина. Скопируй этот файл в .env и заполни.
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────────

# Токен бота от @BotFather.
# Как получить: открой https://t.me/BotFather → команда /newbot → следуй шагам →
# BotFather пришлёт строку вида 123456789:AAE...   — вставь её сюда.
BOT_TOKEN=

# Твой личный Telegram ID (число). Только эти люди видят админ-панель.
# Как узнать: напиши боту @userinfobot — он ответит "Id: 123456789".
# Несколько администраторов — через запятую: 111111111,222222222
ADMIN_IDS=

# ── СПОСОБ ОПЛАТЫ ────────────────────────────────────────────
# manual   — оплата на карту/крипту вручную, ты подтверждаешь → бот сам выдаёт.
#            Ничего подключать не нужно. Лучший вариант для рублей на карту.
# stars    — Telegram Stars (звёзды). Тоже ничего подключать не нужно,
#            оплата проходит внутри Telegram. Цены задаются в звёздах.
# provider — карты через платёжного провайдера (нужен PROVIDER_TOKEN от @BotFather).
PAYMENT_METHOD=manual

# Валюта (для manual и provider). Например: RUB, USD, EUR, UAH, KZT.
# Для stars валюта всегда звёзды (это поле игнорируется).
CURRENCY=RUB

# Реквизиты для оплаты — нужны ТОЛЬКО при PAYMENT_METHOD=manual.
# Их увидит покупатель. Пример:
#   PAYMENT_DETAILS=Сбербанк 2202 2000 0000 0000 (Иван И.). После оплаты жми «Я оплатил».
PAYMENT_DETAILS=

# Токен провайдера — нужен ТОЛЬКО при PAYMENT_METHOD=provider.
# Получается в @BotFather → твой бот → Payments. Для manual/stars оставь пустым.
PROVIDER_TOKEN=

# ── КРИПТО-ОПЛАТА TON (необязательно) ────────────────────────
# Если заполнить TON_WALLET и TON_RATE — у покупателя появится ещё одна кнопка
# «💎 Криптовалюта TON» рядом с основным способом. Бот сам проверяет перевод по
# блокчейну (toncenter) и выдаёт товар автоматически.
#
# Адрес твоего TON-кошелька, куда поступают оплаты (EQ... или UQ...).
TON_WALLET=
# Курс: сколько единиц твоей цены (из CURRENCY) равно 1 TON.
# Пример: 1 TON = 500 ₽ → TON_RATE=500.
TON_RATE=
# API toncenter. Можно не трогать. Ключ (необязательно) повышает лимиты:
# получить бесплатно у @tonapibot. Оставь пустым — тоже работает.
TON_API_URL=https://toncenter.com/api/v2
TON_API_KEY=

# ── БЭКАПЫ БАЗЫ В TELEGRAM (необязательно) ───────────────────
# Бот будет присылать копию базы (товары, заказы) в указанный чат/канал.
# Как настроить: создай приватный канал → добавь туда своего бота
# администратором → узнай ID канала (перешли любой пост из канала боту
# @userinfobot, он покажет "Forwarded from chat ... Id: -100...").
BACKUP_CHAT_ID=
# Как часто слать бэкап, в часах. 0 — выключено. Пример: 24 (раз в сутки).
BACKUP_INTERVAL_HOURS=0

# ── НЕОБЯЗАТЕЛЬНО ────────────────────────────────────────────

# Название магазина (показывается в приветствии).
SHOP_NAME=Мой магазин

# Контакт поддержки: @username или ссылка https://t.me/username. Можно пусто.
SUPPORT_CONTACT=

# Путь к файлу базы данных (можно не трогать).
DB_PATH=data/shop.db
