# ─────────────────────────────────────────────────────────────
#  Настройки CS2-снайпера. Скопируй в .env и заполни:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────────
# Токен бота от @BotFather (/newbot).
BOT_TOKEN=
# Твой Telegram ID (узнать: @userinfobot). Несколько — через запятую.
ADMIN_IDS=

# ── ПЛОЩАДКИ ─────────────────────────────────────────────────
# Через запятую: dmarket, steam, mock.
#   steam   — только мониторинг/алерты (автопокупки у Steam нет).
#   dmarket — мониторинг + автопокупка по официальному API (нужны ключи ниже).
#   mock    — тестовый маркет-симулятор (для проверки без денег и ключей).
# Пусто = steam (+ dmarket, если заданы ключи).
MARKETS=
# Как часто опрашивать площадки, секунд (минимум 5).
POLL_INTERVAL=30

# ── DMARKET (для автопокупки) ────────────────────────────────
# Ключи создаются в личном кабинете DMarket → Trading API (Public + Secret key).
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=
DMARKET_API_URL=https://api.dmarket.com

# ── ЗАЩИТА (значения по умолчанию; меняются потом кнопками в боте) ──
# Автопокупка включена? По умолчанию ВЫКЛ — сначала протестируй в dry-run.
AUTOBUY=0
# Пробный режим: не тратит реальные деньги, только пишет «купил бы». По умолчанию ВКЛ.
DRY_RUN=1
# Максимальная цена одного предмета, USD.
MAX_ITEM_PRICE=50
# Дневной лимит трат, USD.
DAILY_LIMIT=100
# Не тратить баланс ниже этой суммы, USD (страховка).
MIN_BALANCE=0

# Путь к базе (можно не трогать).
DB_PATH=data/sniper.db
